# AKO Media Agent 环境变量配置模板
# 复制此文件为 secrets.env 并填入实际值
# cp secrets.env.example secrets.env

# =============================================================================
# 数据库配置
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ako_media_agent
DB_USER=root
DB_PASSWORD=your_password_here

# =============================================================================
# 阿里云 NLP API
# =============================================================================
ALIYUN_NLP_ACCESS_KEY_ID=your_access_key_id
ALIYUN_NLP_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_NLP_ENDPOINT=https://nlp.cn-beijing.aliyuncs.com

# =============================================================================
# 大模型 API (文案生成)
# =============================================================================
# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问 (可选)
QWEN_API_KEY=your_qwen_api_key

# =============================================================================
# 代理服务 (住宅IP池)
# =============================================================================
# Bright Data
BRIGHT_DATA_API_KEY=your_bright_data_api_key
BRIGHT_DATA_ZONE=your_zone_name

# DataImpulse (备选)
DATAIMPULSE_API_KEY=your_dataimpulse_api_key

# =============================================================================
# 商业数据 API (可选)
# =============================================================================
XINBANG_API_KEY=your_xinbang_api_key
CHANMAMA_API_KEY=your_chanmama_api_key

# =============================================================================
# 微信桥接 (AKO_ext_wechat_bridge)
# =============================================================================
WECHAT_BRIDGE_URL=http://localhost:8081
WECHAT_BRIDGE_TOKEN=your_bridge_token

# =============================================================================
# AKO-ART-Agent (视觉生成)
# =============================================================================
ART_AGENT_URL=http://localhost:8080
ART_AGENT_TOKEN=your_art_agent_token

# =============================================================================
# 邮件告警
# =============================================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@akobuild.cloud
SMTP_PASSWORD=your_smtp_password
ALERT_EMAIL=admin@akobuild.cloud

# =============================================================================
# 小程序配置
# =============================================================================
MINI_PROGRAM_APPID=your_appid
MINI_PROGRAM_SECRET=your_secret
